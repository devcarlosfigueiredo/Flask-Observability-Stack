# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
APP_VERSION=1.0.0
APP_PORT=5000

# ─── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=observability2024
GRAFANA_PORT=3000

# ─── Prometheus ───────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d

# ─── Loki ─────────────────────────────────────────────────────────────────────
LOKI_PORT=3100

# ─── Alertmanager ─────────────────────────────────────────────────────────────
ALERTMANAGER_PORT=9093
WEBHOOK_PORT=5001

